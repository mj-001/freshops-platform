# FreshOpsPlatform Environment Configuration Example
# Copy this file to .env to configure local variables.

# Core platform branding
PLATFORM_NAME=FreshOpsPlatform
TENANT_NAME="Default Operator"
TENANT_ID=default

# Notification and operations thresholds
EXPIRY_ALERT_DAYS_DEFAULT=3
DELIVERY_LATE_HOURS=3
WRITE_OFF_HIGH_VALUE_KES=1000000

# API Security and Session config
API_KEY_PREFIX=fop
SESSION_SECRET=change-this-in-production

# Rate limiting settings (requests per minute)
RATE_LIMIT_EXTERNAL=60
RATE_LIMIT_INTERNAL=300

# Operations settings
SCHEDULED_CHECK_INTERVAL_MS=900000
NOTIFICATION_RETENTION=500
STATE_FILE_PATH=./state.json

# AI Studio runtime vars
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Firebase / Firestore configuration
# Set DATABASE_ADAPTER=firestore to use Firestore instead of the
# default JSON file adapter.

# DATABASE_ADAPTER=firestore

# Your Firebase project ID (found in Firebase Console > Project Settings)
# DATABASE_URL=your-firebase-project-id

# Path to your Firebase service account JSON key file.
# Download from Firebase Console > Project Settings > Service Accounts.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# For local development with the Firebase Emulator Suite:
# Install: npm install -g firebase-tools
# Start:   firebase emulators:start
# Then set:
# FIRESTORE_EMULATOR_HOST=localhost:8080
# DATABASE_ADAPTER=firestore
# DATABASE_URL=freshops-local
